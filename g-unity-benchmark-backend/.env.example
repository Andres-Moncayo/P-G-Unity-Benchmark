# ── App ──────────────────────────────────────────────────────────────
PROJECT_NAME=Unity Nexus 2026 API
ENVIRONMENT=development                 # development | staging | production

# ── Database (PostgreSQL) ────────────────────────────────────────────
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=npg_QZN5qMuUjv9h
POSTGRES_DB=defaultdb
POSTGRES_PORT=5432

# Esta URL la consume FastAPI/Alembic. Driver síncrono psycopg v3.
DATABASE_URL=postgresql://neondb_owner:npg_QZN5qMuUjv9h@ep-misty-sky-aqh6wq9v-pooler.c-8.us-east-1.aws.neon.tech/defaultdb?sslmode=require&channel_binding=require

# ── Pool ─────────────────────────────────────────────────────────────
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=3600
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── Security / JWT ───────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string_for_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080      # 7 días

# ── Identity rules ───────────────────────────────────────────────────
# Lista separada por coma. Vacío = se acepta cualquier dominio (no recomendado en prod).
ALLOWED_EMAIL_DOMAINS=globant.com

# ── Bootstrap del primer admin (lo consume la migración de seed) ─────
INITIAL_ADMIN_EMAIL=admin@globant.com
INITIAL_ADMIN_PASSWORD=Admin123Change!
INITIAL_ADMIN_FULL_NAME=Platform Admin

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Base de datos comunidad/IA (Aiven PostgreSQL — chat y posts) ─────
# Apunta a la instancia Aiven dedicada para datos de comunidad/IA.
# Si se deja vacío o igual a DATABASE_URL, se usará la misma base de datos.
POSTGRES_URL=postgresql://neondb_owner:npg_QZN5qMuUjv9h@ep-misty-sky-aqh6wq9v-pooler.c-8.us-east-1.aws.neon.tech/defaultdb?sslmode=require&channel_binding=require

# ── IA / Search API Keys ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
TAVILY_API_KEY=your_tavily_api_key_here
